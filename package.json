{
  "name": "dajcreative",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npx concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm -w @dajcreative/web run dev",
    "dev:api": "npm -w @dajcreative/api run dev",
    "build:web": "npm -w @dajcreative/web run build",
    "build:api": "npm -w @dajcreative/api run build"
  }
}
